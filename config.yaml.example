ttlock:
  client_id: "tu_client_id"
  client_secret: "tu_client_secret"
  username: "tu_email_ttlock"
  password_md5: "md5_de_tu_password"
  lock_id: 0
  lock_name: "Puerta Principal"
  api_url: "https://euapi.ttlock.com"
  vercel_url: "https://tu-proyecto.vercel.app"
  api_key: "tu_api_key_vercel"
  polling_interval: 5
  token_file: "ttlock_token.cache"
  battery_alert_threshold: 30

  # ──────────────────────────────────────────────────────
  # Tabla de referencia — recordType (TTLock Cloud API)
  # ──────────────────────────────────────────────────────
  # recordType | Descripción                              | Nivel
  # -----------|------------------------------------------|----------
  # 1          | Unlock by app                            | normal
  # 4          | Unlock by passcode                       | normal
  # 7          | Unlock by IC card                        | normal
  # 8          | Unlock by fingerprint                    | normal
  # 9          | Unlock by wrist strap                    | normal
  # 10         | Unlock by mechanical key                 | normal
  # 12         | Unlock by gateway                        | normal
  # 29         | Fuerza aplicada a la cerradura           | critico
  # 30         | Sensor de puerta — cerrada               | (ignorado)
  # 31         | Sensor de puerta — abierta               | alto
  # 32         | Abierta desde adentro                    | normal
  # 44         | Alerta de manipulación (tamper)          | critico
  # 48         | Sistema bloqueado (intentos fallidos)    | critico
  # 50         | Desbloqueado por alta temperatura        | critico
  # 64         | Alarma puerta sin cerrar                 | alto
  # 65         | Falló al abrir                           | alto
  # 66         | Falló al cerrar                          | normal
  #
  # Nota: cualquier unlock (1,4,7,8,9,10,12) con success=0
  # se reclasifica automáticamente a nivel "alto"
  # ──────────────────────────────────────────────────────
  event_levels:
    informativo: [0, 0]
    normal:      [1, 0]
    alto:        [1, 1]
    critico:     [1, 1]

camera:
  rtsp_url: "rtsp://usuario:password@IP:554/ch02/0"
  ffmpeg_path: "ffmpeg"
  capture_on_open: true

whatsapp:
  gateway_url: "http://127.0.0.1:3000"
  recipients:
    - "521XXXXXXXXXX"
    - ""
    - ""

storage:
  photos_dir: "C:\\ttlock-alert\\fotos"
  retention_days: 90

monitoring:
  daily_report_time: "08:00"
  daily_report_enabled: true

email:
  smtp_server: "smtp.gmail.com"
  smtp_port: 587
  sender: "tucorreo@gmail.com"
  password: "app_password_aqui"
  recipients:
    - "tucorreo@gmail.com"
